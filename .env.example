# Flex robot under test (Kansas)
ROBOT_HOST=192.168.0.20
ROBOT_NAME=KansasFLEX

# Local read-only reference clones (do not modify from this harness)
OPENTRONS_REPO_PATH=./upstream/opentrons
ROBOT_STACK_REPO_PATH=./upstream/robot-stack

# HTTP ports (prior art defaults)
ROBOT_HTTP_PORT=31950
ROBOT_HTTPS_PORT=32313
# Use https when CA trust is configured; milestone 1 defaults to http.
ROBOT_USE_HTTPS=false

# Timeouts
ROBOT_REQUEST_TIMEOUT_SECONDS=30
ROBOT_HEALTH_TIMEOUT_SECONDS=10

# Persistence and artifacts
DATABASE_URL=sqlite+aiosqlite:///./artifacts/flex_testing.db
ARTIFACT_DIRECTORY=./artifacts
LOG_LEVEL=INFO

# Safety: mutations off by default. Do not enable access control via this harness.
ALLOW_MUTATIONS=false
DRY_RUN=false

# Optional credentials for future access-control-on testing (not required when AC is off).
# ROBOT_USERNAME=
# ROBOT_PASSWORD=
